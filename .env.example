# OpenCode Web Configuration
# Copy to Railway environment variables

# Server Settings (REQUIRED)
OPENCODE_SERVER_PASSWORD=your_secure_password_here
OPENCODE_SERVER_USERNAME=admin

# OpenCode Zen API Key (REQUIRED for OpenCode Go)
# Get your key at: https://opencode.ai/auth
OPENCODE_API_KEY=your_opencode_api_key_here

# Optional Settings
# OPENCODE_SERVER_CORS=https://your-domain.com
# OPENCODE_CONFIG_PATH=/workspace/.opencode

# Railway will automatically set PORT
